# Firebase Console → Project settings → Service accounts → Generate new private key
# İndirilen dosyayı bu klasöre kopyalayıp adını verin:
#   .service_account.json
#
# Alternatif: dosya yolunu yazın
# FIREBASE_SERVICE_ACCOUNT_FILE=/Users/xxx/Downloads/firebase-adminsdk-xxxxx.json

CITY_CODE=21
CITY_NAME=Diyarbakır
