rules_version = '2';
// Logo / listing display görselleri. Yazma: giriş yapmış herkes (boyut/tip kısıtlı).
// İleride sadece yönetici yazabilsin istersen: custom claims (request.auth.token.role)
// veya Cloud Function üzerinden yükleme kullanın.
service firebase.storage {
  match /b/{bucket}/o {
    match /listing_display/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Toplu ilan içe aktarma (CSV / Excel / JSON) — sadece kendi klasörüne, boyut sınırlı.
    match /users/{userId}/imports/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('text/.*')
          || request.resource.contentType.matches('application/.*')
        );
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
