rules_version = '2';
// Firebase Storage — Emlak Master (avatar / ofis logosu / vitrin / ofis içe aktarma).
// Firestore üyelik dokümanları: office_memberships/{uid}_{officeId}
service firebase.storage {
  match /b/{bucket}/o {

    function userDocData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdminUser() {
      let d = userDocData();
      return d != null && d.role == 'super_admin';
    }

    function isManagerTierUserDoc() {
      let d = userDocData();
      return d != null && d.role in [
        'super_admin', 'broker_owner', 'broker', 'general_manager', 'office_manager',
        'team_lead', 'manager', 'admin', 'owner'
      ];
    }

    function membershipData(officeId) {
      return firestore.get(
        /databases/(default)/documents/office_memberships/$(request.auth.uid + '_' + officeId)
      ).data;
    }

    function isActiveOfficeMember(officeId) {
      let m = membershipData(officeId);
      return m != null
        && m.officeId == officeId
        && m.userId == request.auth.uid
        && m.status == 'active';
    }

    function canManageOfficeFiles(officeId) {
      let m = membershipData(officeId);
      return m != null
        && m.officeId == officeId
        && m.userId == request.auth.uid
        && m.status == 'active'
        && m.role in ['owner', 'admin', 'manager'];
    }

    // --- Profil avatar: yalnızca kendi klasörü ---
    match /users/{userId}/avatar/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Eski düz dosya adı (migration): users/{uid}/avatar_256.jpg
    match /users/{userId}/avatar_256.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // --- Ofis logosu ---
    match /offices/{officeId}/logo/{fileName} {
      allow read: if request.auth != null && (isActiveOfficeMember(officeId) || isSuperAdminUser());
      allow write: if request.auth != null
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (canManageOfficeFiles(officeId) || isSuperAdminUser());
      allow delete: if request.auth != null && (canManageOfficeFiles(officeId) || isSuperAdminUser());
    }

    // --- Toplu içe aktarma (CSV / JSON / XLSX) — ofis yöneticisi veya süper admin ---
    match /offices/{officeId}/imports/{sessionId}/{fileName} {
      allow read: if request.auth != null && (isActiveOfficeMember(officeId) || isSuperAdminUser());
      allow write: if request.auth != null
        && (canManageOfficeFiles(officeId) || isSuperAdminUser())
        && request.resource.size < 16 * 1024 * 1024
        && (
          request.resource.contentType.matches('text/.*')
          || request.resource.contentType == 'application/json'
          || request.resource.contentType == 'application/vnd.ms-excel'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        );
      allow delete: if request.auth != null && (canManageOfficeFiles(officeId) || isSuperAdminUser());
    }

    // --- Global vitrin logosu (app_settings listing_display) — yalnızca yönetici tier ---
    match /listing_display/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && isManagerTierUserDoc()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && isManagerTierUserDoc();
    }

    // Eski yol: kullanıcı başına import (devre dışı — yeni yüklemeler ofis altında)
    match /users/{userId}/imports/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
