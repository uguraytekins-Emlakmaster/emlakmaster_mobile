rules_version = '2';
// Logo / listing display görselleri. Yazma: giriş yapmış herkes (boyut/tip kısıtlı).
// İleride sadece yönetici yazabilsin istersen: custom claims (request.auth.token.role)
// veya Cloud Function üzerinden yükleme kullanın.
service firebase.storage {
  match /b/{bucket}/o {
    match /listing_display/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
