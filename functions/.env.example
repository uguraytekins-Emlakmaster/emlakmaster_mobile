# Firebase Functions (Google Cloud) ortam değişkeni olarak ayarlayın.
# Konsol: Firebase → Functions → [fonksiyon] → Ortam değişkenleri
# veya: firebase functions:secrets:set / gcloud

# hybrid | ingest_only | direct_only
SCRAPER_MODE=hybrid

# ingestListingsPipeline için paylaşılan gizli anahtar
INGEST_SECRET=change-me-to-a-long-random-string

# İsteğe bağlı: Bright Data / Zyte residential veya kurumsal HTTP proxy
# HTTPS_PROXY=http://user:pass@brd.superproxy.io:33335
