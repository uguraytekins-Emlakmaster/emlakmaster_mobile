rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Yönetici: users.role belirtilen rollerden biri ise tüm veriyi görebilir.
    // Doküman yoksa veya role yoksa u.data/role null olur; null in [...] false döner, hata vermez.
    function isManager() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u != null && u.data != null && u.data.role in ['super_admin', 'broker_owner', 'broker', 'general_manager', 'office_manager', 'team_lead', 'manager', 'admin', 'owner'];
    }
    // Veri izolasyonu: danışman sadece kendi atanmış müşteri/çağrılarını görür; yönetici hepsini.
    function isOwnAgentData(agentIdField) {
      return agentIdField == request.auth.uid;
    }

    // Harici ilan: istemciden (Market Pulse) güvenli yazım — Blaze/Functions olmadan.
    function isClientExternalListingWrite(docId) {
      let d = request.resource.data;
      return docId.size() < 300
        && d.clientFetched == true
        && d.source in ['sahibinden', 'emlakjet', 'hepsiEmlak', 'demo']
        && d.externalId is string && d.externalId.size() > 0 && d.externalId.size() < 200
        && d.title is string && d.title.size() > 0 && d.title.size() < 500
        && d.cityCode is string && d.cityCode.size() < 32
        && d.cityName is string && d.cityName.size() < 200
        && d.postedAt is timestamp
        && d.link is string && d.link.size() < 2000
        && d.link.matches('^https?://.+');
    }

    // Blaze olmadan Spark: istemci Market Pulse rollup (Cloud Functions yerine).
    function isClientHeatmapRollup(docId, d) {
      return docId.size() < 32
        && docId.matches('^heatmap_20[0-9]{2}-[0-1][0-9]-[0-3][0-9]$')
        && d.source == 'client_rollup_v1'
        && d.date is string && d.date.size() == 10
        && d.regions is list && d.regions.size() > 0 && d.regions.size() <= 12;
    }
    function isClientDiscoveryRollup(docId, d) {
      return docId.size() < 32
        && docId.matches('^discovery_20[0-9]{2}-[0-1][0-9]-[0-3][0-9]$')
        && d.source == 'client_rollup_v1'
        && d.date is string && d.date.size() == 10
        && d.items is list && d.items.size() <= 30;
    }

    // Kullanıcı (owner) kendi profilinde yalnızca güvenli alanları değiştirebilir;
    // role / isActive / teamId / managerId / createdAt değişimi sadece yönetici (yetki yükseltmesi önlenir).
    function userOwnerUpdatePreservesPrivileges() {
      let absent = '__absent__';
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.get('teamId', absent) == resource.data.get('teamId', absent)
        && request.resource.data.get('managerId', absent) == resource.data.get('managerId', absent)
        && request.resource.data.get('createdAt', absent) == resource.data.get('createdAt', absent);
    }

    // --- Phase 1.3: ofis üyeliği / davet ---
    function officeMembershipId(uid, officeId) {
      return uid + '_' + officeId;
    }
    function officeMembershipDoc(uid, officeId) {
      return get(/databases/$(database)/documents/office_memberships/$(officeMembershipId(uid, officeId)));
    }
    function officeRoleToUserRole(r) {
      return r == 'owner' ? 'broker_owner'
        : r == 'admin' ? 'office_manager'
        : r == 'manager' ? 'team_lead'
        : r == 'consultant' ? 'agent'
        : '';
    }
    function isActiveOfficeMember(officeId) {
      let m = officeMembershipDoc(request.auth.uid, officeId);
      return m != null && m.data != null
        && m.data.officeId == officeId
        && m.data.userId == request.auth.uid
        && m.data.status == 'active';
    }
    function canManageOfficeMembers(officeId) {
      let m = officeMembershipDoc(request.auth.uid, officeId);
      return m != null && m.data != null
        && m.data.status == 'active'
        && m.data.role in ['owner', 'admin', 'manager'];
    }
    function userPreservesOfficeId() {
      return request.resource.data.get('officeId', '') == resource.data.get('officeId', '');
    }
    /// İlk ofis bağlama: users.officeId boşken üyelik dokümanı ile uyumlu role/officeId yazımı.
    function userOfficeJoinAllowed() {
      let oid = request.resource.data.officeId;
      let old = resource.data.get('officeId', '');
      let m = officeMembershipDoc(request.auth.uid, oid);
      return isOwner(request.auth.uid)
        && (old == '' || old == null)
        && oid is string && oid.size() > 0
        && m != null && m.data != null
        && m.data.userId == request.auth.uid
        && m.data.officeId == oid
        && m.data.status == 'active'
        && request.resource.data.role == officeRoleToUserRole(m.data.role);
    }
    /// Üyelik yokken işaretçi temizleme (migration / kurtarma).
    function userClearsInvalidOfficePointer() {
      let oid = resource.data.get('officeId', '');
      return isOwner(request.auth.uid)
        && oid is string && oid.size() > 0
        && request.resource.data.get('officeId', '') == ''
        && !exists(/databases/$(database)/documents/office_memberships/$(officeMembershipId(request.auth.uid, oid)));
    }
    /// Yönetici üyeliği removed yaptıktan sonra hedef kullanıcının officeId temizliği.
    function managerClearedRemovedMemberOfficePointer(userId) {
      let oid = resource.data.get('officeId', '');
      let m = officeMembershipDoc(userId, oid);
      return request.auth.uid != userId
        && oid is string && oid.size() > 0
        && request.resource.data.get('officeId', '') == ''
        && m != null && m.data != null
        && m.data.userId == userId
        && m.data.status == 'removed'
        && canManageOfficeMembers(oid);
    }

    /// `users/{uid}.officeId` — boş string yoksa ofis bağlamı.
    function userOfficeId(uid) {
      let u = get(/databases/$(database)/documents/users/$(uid));
      return u != null && u.data != null ? u.data.get('officeId', '') : '';
    }
    /// Okuyucu ile atanmış danışman aynı ofiste mi (çok kiracılı izolasyon).
    function sameOfficeAsAssignedAgent(assignedAgentId) {
      let ro = userOfficeId(request.auth.uid);
      let ao = userOfficeId(assignedAgentId);
      return ro is string && ro.size() > 0 && ao == ro;
    }
    /// Broker / ofis yöneticisi / ekip lideri vb. (super_admin hariç — ayrı global kural).
    function isOfficeManagerTierRole() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u != null && u.data != null
        && u.data.role in ['broker_owner', 'broker', 'general_manager', 'office_manager', 'team_lead', 'manager', 'admin', 'owner'];
    }
    function isSuperAdminUser() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u != null && u.data != null && u.data.role in ['super_admin'];
    }
    /// Üyelik dokümanı: owner / admin / manager (danışman değil) — users.role gecikmeli olsa da ofis yönetimi tanınır.
    function isActiveOfficeManagerMembership(oid) {
      let m = officeMembershipDoc(request.auth.uid, oid);
      return m != null && m.data != null
        && m.data.status == 'active'
        && m.data.role in ['owner', 'admin', 'manager'];
    }
    function isOfficeManagerForIntelligence(oid) {
      return isOfficeManagerTierRole() || isActiveOfficeManagerMembership(oid);
    }
    /// customers kurallarında get(users/assignedAgentId) için: aynı ofisteki danışman profiline yönetici okuması.
    function canReadColleagueUserForOfficeIntelligence(userId) {
      let oid = userOfficeId(request.auth.uid);
      return oid is string && oid.size() > 0
        && isActiveOfficeMember(oid)
        && sameOfficeAsAssignedAgent(userId)
        && isOfficeManagerForIntelligence(oid);
    }
    /// Ofis içi istihbarat: atanmış danışman aynı ofiste + okuyucu aktif üye + yönetici (users.role veya üyelik).
    function canAccessCustomerOfficeWide() {
      let agentId = resource.data.get('assignedAgentId', '');
      let oid = userOfficeId(request.auth.uid);
      return agentId is string && agentId.size() > 0
        && oid is string && oid.size() > 0
        && isActiveOfficeMember(oid)
        && sameOfficeAsAssignedAgent(agentId)
        && isOfficeManagerForIntelligence(oid);
    }
    function canCreateCustomerAsOfficeManager() {
      let assignedId = request.resource.data.get('assignedAgentId', '');
      let oid = userOfficeId(request.auth.uid);
      return assignedId is string && assignedId.size() > 0
        && oid is string && oid.size() > 0
        && isActiveOfficeMember(oid)
        && sameOfficeAsAssignedAgent(assignedId)
        && isOfficeManagerForIntelligence(oid);
    }
    function canUpdateCustomerAsOfficeManager() {
      let agentId = resource.data.get('assignedAgentId', '');
      let oid = userOfficeId(request.auth.uid);
      return agentId is string && agentId.size() > 0
        && oid is string && oid.size() > 0
        && isActiveOfficeMember(oid)
        && sameOfficeAsAssignedAgent(agentId)
        && isOfficeManagerForIntelligence(oid);
    }

    // -------------------------------------------------------------------------
    // users: kullanıcı kendi dokümanını MUTLAKA okuyabilir (giriş sonrası rol yüklemesi için).
    // isOwner önce kontrol edilir; böylece kendi dokümanı için isManager() get() çağrılmaz (döngü önlenir).
    // Yönetici (isManager) tüm kullanıcıları görebilir ve alanları güncelleyebilir.
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || isManager()
        || canReadColleagueUserForOfficeIntelligence(userId)
      );
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'role']);
      allow update: if isManager()
        || (isOwner(userId) && userOwnerUpdatePreservesPrivileges() && userPreservesOfficeId())
        || (isOwner(userId) && userOfficeJoinAllowed())
        || (isOwner(userId) && userClearsInvalidOfficePointer()
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role)
        || (managerClearedRemovedMemberOfficePointer(userId)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role);
      allow delete: if false;
    }

    match /offices/{officeId} {
      allow read: if isSignedIn() && (isManager() || isActiveOfficeMember(officeId));
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'createdBy']);
      allow update: if isManager()
        || (isActiveOfficeMember(officeId)
            && officeMembershipDoc(request.auth.uid, officeId).data.role in ['owner', 'admin']);
      allow delete: if false;
    }

    match /office_memberships/{membershipId} {
      allow read: if isSignedIn() && (
        isManager()
        || resource.data.userId == request.auth.uid
        || isActiveOfficeMember(resource.data.officeId)
      );
      allow create: if isSignedIn()
        && membershipId == officeMembershipId(request.resource.data.userId, request.resource.data.officeId)
        && request.resource.data.keys().hasAll(['userId', 'officeId', 'role', 'status'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role in ['owner', 'admin', 'manager', 'consultant'];
      allow update: if isManager()
        || (canManageOfficeMembers(resource.data.officeId)
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.officeId == resource.data.officeId)
        || (resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.officeId == resource.data.officeId
            && resource.data.status in ['invited', 'removed']
            && request.resource.data.status == 'active'
            && request.resource.data.role in ['admin', 'manager', 'consultant']);
      allow delete: if false;
    }

    function officeInviteIncrementConsistent() {
      let r = resource.data;
      let req = request.resource.data;
      return r.isActive == true
        && req.usedCount == r.usedCount + 1
        && req.officeId == r.officeId
        && req.code == r.code
        && req.createdBy == r.createdBy
        && req.maxUses == r.maxUses
        && req.roleToAssign == r.roleToAssign
        && req.isActive == r.isActive;
    }

    match /office_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.officeId is string
        && request.resource.data.roleToAssign in ['admin', 'manager', 'consultant']
        && request.resource.data.keys().hasAll(['officeId', 'code', 'createdBy', 'maxUses', 'usedCount', 'roleToAssign', 'isActive'])
        && canManageOfficeMembers(request.resource.data.officeId);
      allow update: if isSignedIn() && (
        canManageOfficeMembers(resource.data.officeId)
        || officeInviteIncrementConsistent()
      );
      allow delete: if false;
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // agents: giriş yapmış herkes listeleyebilir (dashboard); yazma kendi id veya manager
    // (İsteğe bağlı: sadece kendi agent doc'una yazma kısıtı eklenebilir.)
    // -------------------------------------------------------------------------
    match /agents/{agentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isOwnAgentData(agentId) || isManager());
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // customers: DATA SILOING
    // - Danışman: yalnızca assignedAgentId == auth.uid (kendi portföyü).
    // - Broker / ofis yöneticisi: aynı ofisteki danışmanların müşterileri (users.officeId eşleşmesi + aktif üyelik).
    // - super_admin: kurumsal destek için tüm müşteriler (dar rol).
    // Çapraz ofis okuma/yazma: isManager() blanket kaldırıldı; office boundary zorunlu.
    // -------------------------------------------------------------------------
    match /customers/{customerId} {
      allow read: if isSignedIn() && (
        resource.data.assignedAgentId == request.auth.uid
        || canAccessCustomerOfficeWide()
        || isSuperAdminUser()
      );
      allow create: if isSignedIn() && (
        request.resource.data.assignedAgentId == request.auth.uid
        || canCreateCustomerAsOfficeManager()
        || isSuperAdminUser()
      );
      allow update: if isSignedIn() && (
        resource.data.assignedAgentId == request.auth.uid
        || canUpdateCustomerAsOfficeManager()
        || isSuperAdminUser()
      );
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // calls: danışman sadece kendi agentId'li çağrıları görür; yönetici hepsini
    // -------------------------------------------------------------------------
    match /calls/{docId} {
      allow read: if isSignedIn() && (isManager() || resource.data.agentId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.agentId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    match /deals/{docId} {
      allow read: if isSignedIn() && (isManager() || resource.data.agentId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.agentId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.agentId == request.auth.uid);
      allow delete: if false;
    }

    // agentId veya assignedAgentId (AI Call Brain / haftalık sorgu ile uyumlu)
    match /call_summaries/{docId} {
      allow read: if isSignedIn() && (isManager()
        || resource.data.agentId == request.auth.uid
        || resource.data.assignedAgentId == request.auth.uid);
      allow create: if isSignedIn() && (isManager()
        || request.resource.data.agentId == request.auth.uid
        || request.resource.data.assignedAgentId == request.auth.uid);
      allow update: if isSignedIn() && (isManager()
        || resource.data.agentId == request.auth.uid
        || resource.data.assignedAgentId == request.auth.uid);
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // listings: giriş yapmış herkes okuyabilir;
    // oluşturma/güncelleme SADECE yönetici / ofis yetkilisi
    // -------------------------------------------------------------------------
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isManager();
      allow delete: if false;
    }

    match /app_settings/{docId} {
      allow read: if isSignedIn();
      // Uygulama ayarları sadece yönetici tarafından güncellenebilir.
      allow write: if isSignedIn() && isManager();
    }
    match /external_listings/{docId} {
      allow read: if isSignedIn();
      // Cloud Functions (Admin SDK) kuralları bypass eder. İstemci yazımı: Market Pulse
      // "İlanları güncelle" — yalnızca clientFetched + şema doğrulaması (Blaze gerekmez).
      allow create, update: if isSignedIn() && isClientExternalListingWrite(docId);
      allow delete: if false;
    }

    // Harici hesap bağlantıları (Rainbow CRM entegrasyonları). Yazma yalnızca backend.
    match /external_connections/{connId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isManager());
      allow create, update, delete: if false;
    }

    // Bağlantı senkronu ile gelen ilanlar (Benim İlanlarım). Yazma yalnızca Functions.
    match /integration_listings/{listingId} {
      allow read: if isSignedIn()
        && (resource.data.ownerUserId == request.auth.uid || isManager());
      allow create, update, delete: if false;
    }

    // Resmi connector / senkron yapılandırması — salt okuma; yazma Admin SDK.
    match /listing_sources/{docId} {
      allow read: if isSignedIn()
        && (resource.data.officeId == userOfficeId(request.auth.uid) || isManager());
      allow create, update, delete: if false;
    }
    match /listing_sync_runs/{docId} {
      allow read: if isSignedIn()
        && (resource.data.officeId == userOfficeId(request.auth.uid) || isManager());
      allow create, update, delete: if false;
    }
    match /listing_sync_errors/{docId} {
      allow read: if isSignedIn()
        && (resource.data.officeId == userOfficeId(request.auth.uid) || isManager());
      allow create, update, delete: if false;
    }
    match /news/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /office_activity/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /audit_logs/{docId} {
      allow read: if isManager();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // teams: ekipler sadece yönetici tarafından okunur/yazılır.
    match /teams/{teamId} {
      allow read, write: if isSignedIn() && isManager();
    }

    // invites: davetler. Yönetici oluşturur/okur/siler; kullanıcı sadece kendi email'ine ait daveti okuyabilir (ilk girişte uygulama için).
    match /invites/{inviteId} {
      allow create: if isSignedIn() && isManager();
      allow read: if isSignedIn() && (isManager() || resource.data.email == request.auth.token.email);
      allow update, delete: if isSignedIn() && isManager();
    }

    // notes: danışman sadece kendi eklediği notlara (advisorId == uid) veya yönetici hepsine
    match /notes/{noteId} {
      allow read: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.advisorId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow delete: if false;
    }

    // tasks: danışman kendi görevleri (advisorId)
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.advisorId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow delete: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
    }

    // visits: danışman sadece kendi advisorId'li kayıtları görür/oluşturur/günceller; yönetici hepsini.
    match /visits/{visitId} {
      allow read: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.advisorId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow delete: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
    }

    // offers: danışman sadece kendi advisorId'li teklifleri görür/oluşturur/günceller; yönetici hepsini.
    match /offers/{offerId} {
      allow read: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.advisorId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow delete: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
    }

    // pipeline_items: danışman kendi pipeline
    match /pipeline_items/{itemId} {
      allow read: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow create: if isSignedIn() && (isManager() || request.resource.data.advisorId == request.auth.uid);
      allow update: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
      allow delete: if isSignedIn() && (isManager() || resource.data.advisorId == request.auth.uid);
    }

    // analytics: yönetici yazar; ayrıca giriş yapmış kullanıcı güvenli istemci rollup (Spark, Blaze gerekmez).
    match /analytics_daily/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isManager()
        || (isSignedIn() && (
          isClientHeatmapRollup(docId, request.resource.data)
          || isClientDiscoveryRollup(docId, request.resource.data)
        ));
      allow delete: if isManager();
    }
    match /analytics_monthly/{docId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // notifications: kullanıcı kendi bildirimleri (userId alanı varsa)
    match /notifications/{docId} {
      allow read: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
    }

    // Import Engine: görevler yalnızca Cloud Functions (Admin) ile yazılır; istemci okur.
    match /listing_import_tasks/{taskId} {
      allow read: if isSignedIn()
        && (resource.data.ownerUserId == request.auth.uid || isManager());
      allow create, update, delete: if false;
    }

    // Senkron / import logları — salt okuma (owner veya yönetici).
    match /integration_sync_logs/{docId} {
      allow read: if isSignedIn()
        && (resource.data.ownerUserId == request.auth.uid || isManager());
      allow create, update, delete: if false;
    }

    // AI idempotency / kota: yalnız Cloud Functions (Admin SDK); istemci erişimi yok.
    match /ai_idempotency_cache/{docId} {
      allow read, write: if false;
    }
    match /users/{userId}/_ai_remote_quota/{docId} {
      allow read, write: if false;
    }

    // Diğer koleksiyonlar: sadece giriş zorunlu; yazma varsayılan kapalı (yukarıda tanımlanmayanlar)
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
